{
  "name": "amc-agent",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && bun build server/index.ts --target=bun --outdir=dist/server",
    "start": "bun run dist/server/index.js",
    "clean": "rm -rf dist dist-server data/xfas.db",
    "lint": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "hono": "^4.12.23",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdf-parse": "1.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
